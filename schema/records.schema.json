{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stair-ai.com/schemas/records.schema.json",
  "title": "Reasoning Ledger Record Schemas",
  "description": "Canonical record schemas for sections 4.1-4.8 of Reasoning_Ledger_SDK_Design_v1.",
  "version": "0.3",
  "$defs": {
    "BehaviorType": {
      "type": "string",
      "enum": [
        "Observing",
        "ToolCalling",
        "Planning",
        "Thinking",
        "Acting",
        "Reflecting",
        "Other"
      ]
    },
    "UuidV4": {
      "type": "string",
      "format": "uuid"
    },
    "EpochMs": {
      "type": "integer",
      "minimum": 0
    },
    "ModelInvocation": {
      "type": "object",
      "required": [
        "provider",
        "model_name"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model_name": {
          "type": "string",
          "minLength": 1
        },
        "model_version": {
          "type": "string"
        },
        "tokens_in": {
          "type": "integer",
          "minimum": 0
        },
        "tokens_out": {
          "type": "integer",
          "minimum": 0
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "temperature": {
          "type": "number"
        },
        "finish_reason": {
          "type": "string"
        },
        "internal_reasoning": {
          "type": "string",
          "description": "Raw internal reasoning / chain-of-thought emitted by the foundation model alongside (and distinct from) its final output. Maps to provider-specific reasoning channels, e.g. DeepSeek 'reasoning_content', OpenAI o-series reasoning summaries, Anthropic extended-thinking blocks, Gemini thoughts. Distinct from the SDK 'Thinking' behavior, which records a deliberate agent thinking step."
        }
      },
      "additionalProperties": false
    },
    "BaseRecord": {
      "type": "object",
      "required": [
        "schema_version",
        "agent_id",
        "session_id",
        "record_id",
        "behavior",
        "client_ts_utc"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "0.3"
          ]
        },
        "agent_id": {
          "$ref": "#/$defs/UuidV4"
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "record_id": {
          "$ref": "#/$defs/UuidV4"
        },
        "behavior": {
          "$ref": "#/$defs/BehaviorType"
        },
        "client_ts_utc": {
          "$ref": "#/$defs/EpochMs"
        },
        "notes": {
          "type": "string",
          "maxLength": 2048
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 64
          },
          "maxItems": 32
        },
        "model_invocation": {
          "$ref": "#/$defs/ModelInvocation"
        },
        "upstream_record_id": {
          "type": "array",
          "items": { "$ref": "#/$defs/UuidV4" },
          "maxItems": 32,
          "description": "DAG dependency / trace sequence. Records this one builds on. May be empty/omitted."
        },
        "parent_record_id": {
          "$ref": "#/$defs/UuidV4",
          "description": "Sub-thread / sub-process containment. Set when this record is produced inside a sub-thread spawned by another record. Records outside the sub-thread do not list internal sub-thread records as upstream. For ordinary DAG dependencies use upstream_record_id instead."
        }
      }
    },
    "ThinkingInput": {
      "type": "object",
      "required": [
        "input_payload"
      ],
      "properties": {
        "input_record_id": {
          "$ref": "#/$defs/UuidV4"
        },
        "input_payload": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ReflectingInput": {
      "type": "object",
      "required": [
        "input_payload"
      ],
      "properties": {
        "input_record_id": {
          "$ref": "#/$defs/UuidV4"
        },
        "input_payload": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "PlanningStep": {
      "type": "object",
      "required": [
        "index",
        "description"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": false
    },
    "ObservingRecord": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseRecord"
        },
        {
          "type": "object",
          "required": [
            "behavior",
            "trigger_source",
            "trigger_type",
            "trigger_description",
            "trigger_payload_summary"
          ],
          "properties": {
            "behavior": {
              "const": "Observing"
            },
            "trigger_source": {
              "type": "string",
              "minLength": 1
            },
            "trigger_type": {
              "type": "string",
              "enum": [
                "signal_trigger",
                "cron_trigger"
              ]
            },
            "external_trigger_id": {
              "type": "string"
            },
            "event_ts_utc": {
              "$ref": "#/$defs/EpochMs"
            },
            "trigger_description": {
              "type": "string",
              "minLength": 1
            },
            "trigger_payload_summary": {
              "type": "string",
              "maxLength": 4096
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "ToolCallingRecord": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseRecord"
        },
        {
          "type": "object",
          "required": [
            "behavior",
            "tool_meta",
            "description",
            "input_payload",
            "output_payload",
            "success"
          ],
          "properties": {
            "behavior": {
              "const": "ToolCalling"
            },
            "tool_meta": {
              "type": "object",
              "additionalProperties": true
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "input_payload": true,
            "output_payload": true,
            "success": {
              "type": "boolean"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "PlanningRecord": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseRecord"
        },
        {
          "type": "object",
          "required": [
            "behavior",
            "goal",
            "steps"
          ],
          "properties": {
            "behavior": {
              "const": "Planning"
            },
            "goal": {
              "type": "string",
              "minLength": 1
            },
            "steps": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/PlanningStep"
              }
            },
            "contingencies": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "ThinkingRecord": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseRecord"
        },
        {
          "type": "object",
          "required": [
            "behavior",
            "prompt",
            "inputs",
            "output_payload"
          ],
          "properties": {
            "behavior": {
              "const": "Thinking"
            },
            "prompt": {
              "type": "string",
              "minLength": 1
            },
            "inputs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ThinkingInput"
              }
            },
            "output_payload": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "ActingRecord": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseRecord"
        },
        {
          "type": "object",
          "required": [
            "behavior",
            "action_type",
            "target_system",
            "action_summary",
            "parameters",
            "dry_run",
            "execution_status"
          ],
          "properties": {
            "behavior": {
              "const": "Acting"
            },
            "action_type": {
              "type": "string",
              "minLength": 1
            },
            "target_system": {
              "type": "string",
              "minLength": 1
            },
            "action_summary": {
              "type": "string",
              "minLength": 1
            },
            "parameters": {
              "type": "object",
              "additionalProperties": true
            },
            "dry_run": {
              "type": "boolean"
            },
            "execution_id": {
              "type": "string"
            },
            "execution_status": {
              "type": "string",
              "enum": [
                "confirmed",
                "failed",
                "simulated",
                "pending"
              ]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "target_system": {
                    "const": "public-chain"
                  },
                  "execution_status": {
                    "const": "confirmed"
                  }
                },
                "required": [
                  "target_system",
                  "execution_status"
                ]
              },
              "then": {
                "required": [
                  "execution_id"
                ]
              }
            }
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "ReflectingRecord": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseRecord"
        },
        {
          "type": "object",
          "required": [
            "behavior",
            "inputs",
            "output_payload"
          ],
          "properties": {
            "behavior": {
              "const": "Reflecting"
            },
            "inputs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ReflectingInput"
              }
            },
            "output_payload": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "OtherRecord": {
      "allOf": [
        {
          "$ref": "#/$defs/BaseRecord"
        },
        {
          "type": "object",
          "required": [
            "behavior",
            "label",
            "data"
          ],
          "properties": {
            "behavior": {
              "const": "Other"
            },
            "label": {
              "type": "string",
              "minLength": 1
            },
            "data": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "Record": {
      "oneOf": [
        {
          "$ref": "#/$defs/ObservingRecord"
        },
        {
          "$ref": "#/$defs/ToolCallingRecord"
        },
        {
          "$ref": "#/$defs/PlanningRecord"
        },
        {
          "$ref": "#/$defs/ThinkingRecord"
        },
        {
          "$ref": "#/$defs/ActingRecord"
        },
        {
          "$ref": "#/$defs/ReflectingRecord"
        },
        {
          "$ref": "#/$defs/OtherRecord"
        }
      ],
      "discriminator": {
        "propertyName": "behavior",
        "mapping": {
          "Observing": "#/$defs/ObservingRecord",
          "ToolCalling": "#/$defs/ToolCallingRecord",
          "Planning": "#/$defs/PlanningRecord",
          "Thinking": "#/$defs/ThinkingRecord",
          "Acting": "#/$defs/ActingRecord",
          "Reflecting": "#/$defs/ReflectingRecord",
          "Other": "#/$defs/OtherRecord"
        }
      }
    }
  },
  "$ref": "#/$defs/Record"
}
