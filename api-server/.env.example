# Database connection string (required)
DATABASE_URL=postgres://user:password@localhost:5432/reasoning_ledger

# Server configuration
PORT=3000
HOST=127.0.0.1

# Proxy encryption key (required for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PROXY_ENCRYPTION_KEY=

# Optional: Override default upstream API URLs
SPORTMONKS_BASE_URL=https://api.sportmonks.com
POLYMARKET_BASE_URL=https://api.polymarket.com
